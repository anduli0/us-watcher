# US-WATCHER environment template. Copy to `.env` and override as needed.
# NEVER commit `.env`. Secrets are server-only.

# --- App ---
APP_ENV=development
SERVER_TIMEZONE=America/New_York

# --- Persistence ---
# SQLite (default, dockerless) or Postgres (prod):
#   postgresql+asyncpg://user:pass@host:5432/us_watcher
DATABASE_URL=sqlite+aiosqlite:///./us_watcher.db
# Empty -> in-memory fakeredis fallback (reported honestly at /health)
REDIS_URL=

# --- Market data (provider-adapter) ---
# "yahoo" = real, keyless quotes/aggregates; "mock" = offline labelled sample data
MARKET_DATA_PROVIDER=yahoo
MARKET_DATA_TTL_SECONDS=60

# --- Macro data ---
# FRED keyless CSV is used by default. An API key (optional) unlocks the JSON API
# and ALFRED vintages. Get one free at https://fred.stlouisfed.org/docs/api/
FRED_API_KEY=

# --- News ---
# "google" = keyless Google News RSS; "mock" = offline
NEWS_PROVIDER=google
NEWS_RETENTION_DAYS=21

# --- LLM agents (provider-abstracted; system still runs with ZERO providers in mock mode) ---
AGENT_RUNTIME=mock
# Reasoning model: specialist investment analysis
LLM_REASONING_PROVIDER=anthropic
LLM_REASONING_MODEL=claude-opus-4-8
# Fast model: classification, entity extraction, dedup
LLM_FAST_PROVIDER=anthropic
LLM_FAST_MODEL=claude-haiku-4-5-20251001
# Independent critic model: adversarial review
LLM_CRITIC_PROVIDER=anthropic
LLM_CRITIC_MODEL=claude-sonnet-4-6
# Editor model: final KO/EN writing
LLM_EDITOR_PROVIDER=anthropic
LLM_EDITOR_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
AGENT_RUN_TOKEN_BUDGET=120000

# --- Web / HTTP ---
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Operational security ---
# Required to invoke protected pipeline / admin endpoints (POST /api/v1/pipelines/*).
CRON_SECRET=
ADMIN_API_KEY=

# --- Notifications (optional; delivery skipped if unset, never fabricated) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
